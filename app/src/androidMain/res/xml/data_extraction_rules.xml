<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude database and preferences from cloud backup to prevent data leaks -->
        <exclude domain="database" path="LoopHabit" />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
        <exclude domain="root" path="LoopHabit" />
    </cloud-backup>
    <device-transfer>
        <!-- Exclude sensitive data from device transfer as well -->
        <exclude domain="database" path="LoopHabit" />
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>